{
  "openapi": "3.0.0",
  "info": {
    "title": "Field Service Management (FSM) Mobile API",
    "version": "1.0.0",
    "description": "API documentation for the Field Service Management (FSM) Mobile application. Contains routes for authentication, technicians, progress tracking, location updates, proof of work, and admin dashboard/management."
  },
  "servers": [
    {
      "url": "http://localhost:8000/api",
      "description": "Local development server"
    }
  ],
  "components": {
    "securitySchemes": {
      "SanctumAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Enter your Laravel Sanctum plain text token here."
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "phone": { "type": "string", "nullable": true },
          "role": { "type": "string", "enum": ["admin", "technician"] },
          "is_active": { "type": "boolean" },
          "is_online": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "Task": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "title": { "type": "string" },
          "customer_name": { "type": "string" },
          "description": { "type": "string" },
          "address": { "type": "string" },
          "latitude": { "type": "number", "nullable": true },
          "longitude": { "type": "number", "nullable": true },
          "technician_id": { "type": "integer", "nullable": true },
          "status": { "type": "string", "enum": ["assigned", "accepted", "on-going", "completed"] },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "ProgressUpdate": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "task_id": { "type": "integer" },
          "user_id": { "type": "integer" },
          "note": { "type": "string" },
          "progress_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "ProofOfWork": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "task_id": { "type": "integer" },
          "image": { "type": "string", "description": "Relative storage path to image" },
          "image_url": { "type": "string", "format": "uri", "description": "Absolute URL to image" },
          "description": { "type": "string", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "TechnicianLocation": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "technician_id": { "type": "integer" },
          "latitude": { "type": "number" },
          "longitude": { "type": "number" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      }
    }
  },
  "security": [
    {
      "SanctumAuth": []
    }
  ],
  "paths": {
    "/login": {
      "post": {
        "summary": "User Login",
        "description": "Logs in a user and returns an authentication token.",
        "security": [],
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "admin@fsm.com" },
                  "password": { "type": "string", "example": "password" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": { "type": "string", "example": "1|abcdef123456" },
                    "user": { "$ref": "#/components/schemas/User" }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Email atau password salah" }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Account inactive",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Akun tidak aktif" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/logout": {
      "post": {
        "summary": "User Logout",
        "description": "Deletes the current access token.",
        "tags": ["Authentication"],
        "responses": {
          "200": {
            "description": "Logout successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Logout berhasil" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/me": {
      "get": {
        "summary": "Get Authenticated User",
        "description": "Retrieves the details of the currently authenticated user.",
        "tags": ["Authentication"],
        "responses": {
          "200": {
            "description": "User details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "$ref": "#/components/schemas/User" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/profile": {
      "put": {
        "summary": "Update Profile",
        "description": "Updates profile details for the authenticated user.",
        "tags": ["Authentication"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string", "example": "Updated Name" },
                  "phone": { "type": "string", "example": "08123456789" },
                  "is_online": { "type": "boolean", "example": true }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Profile updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "$ref": "#/components/schemas/User" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tasks": {
      "get": {
        "summary": "List Technician Tasks",
        "description": "Lists tasks assigned to the authenticated technician, optionally filtered by status.",
        "tags": ["Technician Tasks"],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "required": false,
            "description": "Filter tasks by status",
            "schema": {
              "type": "string",
              "enum": ["assigned", "accepted", "on-going", "completed"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tasks list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "allOf": [
                          { "$ref": "#/components/schemas/Task" },
                          {
                            "type": "object",
                            "properties": {
                              "progress_updates": {
                                "type": "array",
                                "items": { "$ref": "#/components/schemas/ProgressUpdate" }
                              },
                              "proof_of_work": {
                                "type": "array",
                                "items": { "$ref": "#/components/schemas/ProofOfWork" }
                              }
                            }
                          }
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tasks/history": {
      "get": {
        "summary": "Get Task History",
        "description": "Retrieves completed tasks for the authenticated technician.",
        "tags": ["Technician Tasks"],
        "responses": {
          "200": {
            "description": "Completed tasks history list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "allOf": [
                          { "$ref": "#/components/schemas/Task" },
                          {
                            "type": "object",
                            "properties": {
                              "progress_updates": {
                                "type": "array",
                                "items": { "$ref": "#/components/schemas/ProgressUpdate" }
                              },
                              "proof_of_work": {
                                "type": "array",
                                "items": { "$ref": "#/components/schemas/ProofOfWork" }
                              }
                            }
                          }
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tasks/{task}": {
      "get": {
        "summary": "Get Task Details",
        "description": "Gets full task details including technician profile, progress updates, and proof of work.",
        "tags": ["Technician Tasks"],
        "parameters": [
          {
            "name": "task",
            "in": "path",
            "required": true,
            "description": "The Task ID",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Detailed task information",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "allOf": [
                        { "$ref": "#/components/schemas/Task" },
                        {
                          "type": "object",
                          "properties": {
                            "technician": { "$ref": "#/components/schemas/User" },
                            "progress_updates": {
                              "type": "array",
                              "items": {
                                "allOf": [
                                  { "$ref": "#/components/schemas/ProgressUpdate" },
                                  {
                                    "type": "object",
                                    "properties": {
                                      "user": { "$ref": "#/components/schemas/User" }
                                    }
                                  }
                                ]
                              }
                            },
                            "proof_of_work": {
                              "type": "array",
                              "items": { "$ref": "#/components/schemas/ProofOfWork" }
                            }
                          }
                        }
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tasks/{task}/accept": {
      "post": {
        "summary": "Accept Task",
        "description": "Changes the task status to 'accepted'. Only valid if task is currently 'assigned'.",
        "tags": ["Technician Tasks"],
        "parameters": [
          {
            "name": "task",
            "in": "path",
            "required": true,
            "description": "The Task ID",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Task accepted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "$ref": "#/components/schemas/Task" }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Unauthorized access to task",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Unauthorized" }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable transition state",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Tugas tidak dalam status assigned" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tasks/{task}/reject": {
      "post": {
        "summary": "Reject Task",
        "description": "Rejects the assigned task. Reverts technician_id to null and status to 'assigned'. Only valid if task is currently 'assigned'.",
        "tags": ["Technician Tasks"],
        "parameters": [
          {
            "name": "task",
            "in": "path",
            "required": true,
            "description": "The Task ID",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Task rejected successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Tugas ditolak" }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Unauthorized access to task",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Unauthorized" }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Task cannot be rejected",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Tugas tidak bisa ditolak" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tasks/{task}/start": {
      "post": {
        "summary": "Start Task Execution",
        "description": "Starts executing the task. Changes status to 'on-going'. Only valid if task status is 'accepted'.",
        "tags": ["Technician Tasks"],
        "parameters": [
          {
            "name": "task",
            "in": "path",
            "required": true,
            "description": "The Task ID",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Task started",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "$ref": "#/components/schemas/Task" }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Unauthorized" }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Task has not been accepted yet",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Tugas belum diterima" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tasks/{task}/complete": {
      "post": {
        "summary": "Complete Task Execution",
        "description": "Sets task status to 'completed'. Only valid if status is 'on-going'.",
        "tags": ["Technician Tasks"],
        "parameters": [
          {
            "name": "task",
            "in": "path",
            "required": true,
            "description": "The Task ID",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Task marked as completed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "$ref": "#/components/schemas/Task" }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Unauthorized" }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Task has not started yet",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Pekerjaan belum dimulai" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tasks/{task}/progress": {
      "post": {
        "summary": "Store Task Progress Update",
        "description": "Log progress percentages and notes for a task.",
        "tags": ["Technician Tasks"],
        "parameters": [
          {
            "name": "task",
            "in": "path",
            "required": true,
            "description": "The Task ID",
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["note", "progress_percent"],
                "properties": {
                  "note": { "type": "string", "example": "Installing replacement fiber router" },
                  "progress_percent": { "type": "integer", "minimum": 0, "maximum": 100, "example": 50 }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Progress logged successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "$ref": "#/components/schemas/ProgressUpdate" }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Unauthorized to log progress for this task",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Unauthorized" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/location": {
      "post": {
        "summary": "Update Technician GPS Location",
        "description": "Updates current latitude and longitude coordinates of the technician.",
        "tags": ["Technician Tasks"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["latitude", "longitude"],
                "properties": {
                  "latitude": { "type": "number", "format": "float", "example": -6.2088 },
                  "longitude": { "type": "number", "format": "float", "example": 106.8456 }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Location logged successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Lokasi diperbarui" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tasks/{task}/proof": {
      "get": {
        "summary": "Get Proof of Work List",
        "description": "Gets uploaded proof of work list with absolute image URLs.",
        "tags": ["Technician Tasks"],
        "parameters": [
          {
            "name": "task",
            "in": "path",
            "required": true,
            "description": "The Task ID",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of proofs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/ProofOfWork" }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Submit Proof of Work",
        "description": "Upload an image file and description as proof of completed or ongoing work.",
        "tags": ["Technician Tasks"],
        "parameters": [
          {
            "name": "task",
            "in": "path",
            "required": true,
            "description": "The Task ID",
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["image"],
                "properties": {
                  "image": { "type": "string", "format": "binary", "description": "Proof photo (max 5MB)" },
                  "description": { "type": "string", "example": "Finished clean cable management" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Proof uploaded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "$ref": "#/components/schemas/ProofOfWork" }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Unauthorized access to task",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Unauthorized" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/admin/dashboard": {
      "get": {
        "summary": "Admin Dashboard Stats",
        "description": "Returns counts for all task statuses, active technicians, recent tasks, and latest technician GPS locations.",
        "tags": ["Admin Management"],
        "responses": {
          "200": {
            "description": "Admin dashboard data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "stats": {
                      "type": "object",
                      "properties": {
                        "total": { "type": "integer" },
                        "assigned": { "type": "integer" },
                        "accepted": { "type": "integer" },
                        "ongoing": { "type": "integer" },
                        "completed": { "type": "integer" },
                        "active_techs": { "type": "integer" }
                      }
                    },
                    "recent_tasks": {
                      "type": "array",
                      "items": {
                        "allOf": [
                          { "$ref": "#/components/schemas/Task" },
                          {
                            "type": "object",
                            "properties": {
                              "technician": { "$ref": "#/components/schemas/User" }
                            }
                          }
                        ]
                      }
                    },
                    "tech_locations": {
                      "type": "array",
                      "items": {
                        "allOf": [
                          { "$ref": "#/components/schemas/TechnicianLocation" },
                          {
                            "type": "object",
                            "properties": {
                              "technician": { "$ref": "#/components/schemas/User" }
                            }
                          }
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/admin/tasks": {
      "get": {
        "summary": "Admin List All Tasks",
        "description": "Allows administrative users to see all tasks, with optional filters for status and technician.",
        "tags": ["Admin Tasks"],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "technician_id",
            "in": "query",
            "required": false,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "All tasks list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "allOf": [
                          { "$ref": "#/components/schemas/Task" },
                          {
                            "type": "object",
                            "properties": {
                              "technician": { "$ref": "#/components/schemas/User" }
                            }
                          }
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Admin Create Task",
        "description": "Creates a new task with assignment optional.",
        "tags": ["Admin Tasks"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title", "customer_name", "description", "address"],
                "properties": {
                  "title": { "type": "string", "example": "Perbaikan Modem Indihome" },
                  "customer_name": { "type": "string", "example": "Budi Santoso" },
